# --- Scraper ---
# Default output directory for scraped stories (relative to repo root).
# Override with --output / -o on the scrape command.
# STORIES_DIR=data/stories

# --- AI Direction (Phase 2) ---
# Ollama base URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
# Qwen3 8b model name as registered in Ollama
# OLLAMA_MODEL=qwen3:8b

# --- TTS (Phase 3) ---
# HuggingFace model ID for voice cloning (downloaded automatically on first use)
# TTS_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-Base
# PyTorch device to run inference on
# TTS_DEVICE=cuda:0
# Model dtype — bfloat16 recommended for Ampere/Ada GPUs; float16 for older
# TTS_DTYPE=bfloat16
# Directory where voice profiles (prompt.pt + meta.json) are stored
# TTS_PROFILES_DIR=~/.config/qwen3-tts/profiles

# --- Web (Phase 4) ---
# Host and port for the FastAPI web app
# WEB_HOST=0.0.0.0
# WEB_PORT=8000
