# Path to the Python binary inside your venv.
# The speak command (one-shot mode) and tts:serve use this.
# If you created the venv as described in the README:
PYTHON_BIN=.venv/bin/python

# TTS server URL — when set, `speak` will use the warm Gradio server
# instead of spawning a one-shot Python process each time.
# Start the server with: npm run tts:serve
# TTS_SERVER_URL=http://localhost:7860
