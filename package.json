{
  "name": "parseltongue",
  "version": "0.1.0",
  "private": true,
  "description": "Fan fiction pipeline: scrape → enunciate → speak → consume",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "scrape": "node apps/cli/run.js scrape",
    "enunciate": "node apps/cli/run.js enunciate",
    "speak": "node apps/cli/run.js speak",
    "check": "node apps/cli/run.js check",
    "tts:serve": "python packages/tts/server.py",
    "lint": "turbo run lint",
    "postinstall": "npm run postinstall --workspace=@parseltongue/scraper"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "npm",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
